###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_use_bin_console_secret_generate
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: mysql://user:password@host:port/dbname?serverVersion=8.4&charset=utf8mb4
DATABASE_URL="mysql://ged_user:ged_password@127.0.0.1:3306/ged_moderne?serverVersion=8.4&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Transport Redis pour les messages async (indexation, previews, mails)
MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://localhost:1025
###< symfony/mailer ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_strong_passphrase
JWT_TOKEN_TTL=3600
###< lexik/jwt-authentication-bundle ###

###> Storage (Flysystem) ###
# Options: local | s3 | azure
STORAGE_ADAPTER=local
STORAGE_LOCAL_PATH=%kernel.project_dir%/var/storage/documents

# AWS S3 (si STORAGE_ADAPTER=s3)
AWS_S3_BUCKET=
AWS_S3_REGION=eu-west-3
AWS_S3_KEY=
AWS_S3_SECRET=
AWS_S3_ENDPOINT=

# Encryption des fichiers au repos (Sodium)
STORAGE_ENCRYPTION_KEY=
###< Storage ###

###> Meilisearch ###
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=change_me_meilisearch_master_key
###< Meilisearch ###

###> Redis ###
REDIS_URL=redis://localhost:6379
###< Redis ###

###> Rate Limiting ###
RATE_LIMITER_LOGIN_POLICY=sliding_window
RATE_LIMITER_LOGIN_LIMIT=5
RATE_LIMITER_LOGIN_INTERVAL=15 minutes
###< Rate Limiting ###

###> Legacy migration ###
# URL de l'ancienne GED SeedDMS (pour les tests de caractérisation)
LEGACY_GED_URL=http://localhost:8080
LEGACY_GED_DB_URL="mysql://seeddms:seeddms@127.0.0.1:3306/seeddms?serverVersion=8.0"
###< Legacy migration ###
