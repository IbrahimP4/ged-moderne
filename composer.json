{
    "name": "darh-enof/ged-moderne",
    "description": "GED \u2014 Gestion \u00c9lectronique de Documents moderne (Symfony 7.4 LTS)",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-fileinfo": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-sodium": "*",
        "api-platform/core": "^3.4",
        "api-platform/symfony": "^3.4",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.3",
        "league/flysystem": "^3.29",
        "league/flysystem-bundle": "^3.3",
        "league/flysystem-local": "^3.29",
        "league/mime-type-detection": "^1.15",
        "lexik/jwt-authentication-bundle": "^3.1",
        "meilisearch/meilisearch-php": "^1.8",
        "nelmio/cors-bundle": "^2.5",
        "phpoffice/phpword": "^1.4",
        "smalot/pdfparser": "^2.12",
        "symfony/asset": "7.4.*",
        "symfony/cache": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "7.4.*",
        "symfony/http-client": "7.4.*",
        "symfony/lock": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/messenger": "7.4.*",
        "symfony/password-hasher": "7.4.*",
        "symfony/property-access": "7.4.*",
        "symfony/rate-limiter": "7.4.*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/serializer": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/uid": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/workflow": "7.4.*",
        "symfony/yaml": "7.4.*"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.2",
        "doctrine/doctrine-fixtures-bundle": "^3.7",
        "fakerphp/faker": "^1.24",
        "friendsofphp/php-cs-fixer": "^3.75",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-arch": "^3.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "rector/rector": "^2.0",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*",
        "symfony/http-kernel": "7.4.*",
        "symfony/stopwatch": "7.4.*",
        "symfony/web-profiler-bundle": "7.4.*",
        "zenstruck/foundry": "^2.3"
    },
    "suggest": {
        "ext-redis": "N\u00e9cessaire pour le transport Messenger Redis en production",
        "ext-pdo_mysql": "N\u00e9cessaire pour MySQL en production",
        "league/flysystem-aws-s3-v3": "Pour le stockage Amazon S3",
        "infection/infection": "Pour les tests de mutation (make mutation)"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true,
            "pestphp/pest-plugin": true
        },
        "sort-packages": true,
        "platform": {
            "php": "8.4.0"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "test": "vendor/bin/pest",
        "test:unit": "vendor/bin/pest tests/Unit",
        "test:integration": "vendor/bin/pest tests/Integration",
        "test:functional": "vendor/bin/pest tests/Functional",
        "test:characterization": "vendor/bin/pest tests/Characterization",
        "test:coverage": "vendor/bin/pest --coverage --min=85",
        "stan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "stan:baseline": "vendor/bin/phpstan analyse --memory-limit=512M --generate-baseline",
        "cs:check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs:fix": "vendor/bin/php-cs-fixer fix",
        "rector:check": "vendor/bin/rector process --dry-run",
        "rector:fix": "vendor/bin/rector process",
        "qa": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
